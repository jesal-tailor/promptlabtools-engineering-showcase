# Public-safe example values only.
# Copy to .env.local if you want to experiment locally.
# No real secrets are required for local, CI, or Vercel preview use.

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PROMPTLABTOOLS_URL=https://www.promptlabtools.com
NEXT_PUBLIC_FREE_GUIDE_URL=https://www.promptlabtools.com/free-guide

# Mock-only endpoint label used in docs/examples. Do not put real webhooks here.
MOCK_WORKFLOW_DESTINATION=mock://workflow-intake

# Stage 9 deployment/readiness metadata. Keep mock-only.
NEXT_PUBLIC_DEPLOYMENT_ENV=local
NEXT_PUBLIC_LIVE_PREVIEW_STATUS=not-deployed
MOCK_EXTERNAL_CALLS_ENABLED=false
